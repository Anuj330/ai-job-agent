APP_ENV=development
APP_DEBUG=false
APP_LOG_LEVEL=INFO
APP_DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/ai_job_agent
APP_REDIS_URL=redis://redis:6379/0
APP_CELERY_BROKER_URL=redis://redis:6379/1
APP_CELERY_RESULT_BACKEND=redis://redis:6379/2
APP_OPENAI_API_KEY=
APP_OPENAI_MATCHING_MODEL=gpt-4o-mini
APP_OPENAI_REQUEST_TIMEOUT_SECONDS=60
APP_SCHEDULED_SCRAPE_KEYWORDS=python developer
APP_SCHEDULED_SCRAPE_LOCATION=remote
APP_SCHEDULED_SCRAPE_MAX_JOBS=25
APP_SCHEDULED_SCRAPE_SOURCES=["linkedin","naukri","bayt","indeed"]
APP_SCHEDULED_SCRAPE_HOUR=8
APP_SCHEDULED_SCRAPE_MINUTE=0
APP_SMTP_HOST=
APP_SMTP_PORT=587
APP_SMTP_USERNAME=
APP_SMTP_PASSWORD=
APP_SMTP_USE_TLS=true
APP_SMTP_FROM_ADDRESS=
APP_SMTP_TIMEOUT_SECONDS=30
APP_CORS_ORIGINS=["http://localhost:3000"]
APP_LINKEDIN_COOKIES_JSON=[]
APP_NAUKRI_COOKIES_JSON=[]
APP_BAYT_COOKIES_JSON=[]
APP_INDEED_COOKIES_JSON=[]
APP_LINKEDIN_HEADLESS=true
APP_NAUKRI_HEADLESS=true
APP_BAYT_HEADLESS=true
APP_INDEED_HEADLESS=true
APP_SCRAPER_DELAY_MIN_SECONDS=1.5
APP_SCRAPER_DELAY_MAX_SECONDS=3.5
APP_SCRAPER_NAVIGATION_TIMEOUT_MS=30000
# Override the browser user-agent. Leave blank to use a recent desktop Chrome UA.
APP_SCRAPER_USER_AGENT=
# Optional proxy for scraper browsers, e.g. http://user:pass@host:port. A residential
# proxy is strongly recommended for Naukri/LinkedIn: datacenter IPs get rate-limited.
APP_SCRAPER_PROXY_URL=
